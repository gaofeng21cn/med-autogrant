{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/product-status.schema.json",
  "title": "Med Auto Grant Direct Status Handler",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "command",
    "grant_run_id",
    "workspace_id",
    "draft_id",
    "lifecycle_stage",
    "input_path",
    "product_status"
  ],
  "properties": {
    "ok": {"const": true},
    "command": {"const": "product-status"},
    "grant_run_id": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "workspace_id": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "draft_id": {"type": ["string", "null"]},
    "lifecycle_stage": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "input_path": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "product_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "target_domain_id",
        "product_entry_status",
        "summary",
        "product_entry_surfaces",
        "progress_projection",
        "stage_descriptor_ref",
        "owner_receipt_contract",
        "authority_boundary",
        "notes"
      ],
      "properties": {
        "surface_kind": {"const": "product_status"},
        "target_domain_id": {"const": "med-autogrant"},
        "product_entry_status": {"type": "object"},
        "summary": {
          "type": "object",
          "required": ["product_entry_command", "recommended_command", "operator_loop_command"],
          "additionalProperties": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
        },
        "product_entry_surfaces": {"type": "object"},
        "progress_projection": {"type": "object"},
        "stage_descriptor_ref": {"const": "contracts/stage_control_plane.json"},
        "owner_receipt_contract": {"type": "object"},
        "authority_boundary": {"type": "object"},
        "notes": {"$ref": "common.schema.json#/$defs/stringList"}
      }
    }
  }
}
