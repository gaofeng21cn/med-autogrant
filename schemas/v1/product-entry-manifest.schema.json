{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/product-entry-manifest.schema.json",
  "title": "Med Auto Grant Product Entry Manifest",
  "type": "object",
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "workspaceLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_surface_kind",
        "workspace_root",
        "workspace_path"
      ],
      "properties": {
        "workspace_surface_kind": {
          "const": "nsfc_workspace"
        },
        "workspace_root": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "workspace_path": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "formalEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default",
        "supported_protocols",
        "internal_surface"
      ],
      "properties": {
        "default": {
          "const": "CLI"
        },
        "supported_protocols": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/nonEmptyString"
          }
        },
        "internal_surface": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "shellSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shell_key",
        "command",
        "surface_kind",
        "summary"
      ],
      "properties": {
        "shell_key": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "surface_kind": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "operatorLoopAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "surface_kind",
        "summary",
        "requires"
      ],
      "properties": {
        "command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "surface_kind": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "requires": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "operatorLoopActions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_loop",
        "inspect_progress",
        "inspect_cockpit",
        "build_direct_entry",
        "build_submission_ready_package"
      ],
      "properties": {
        "open_loop": {
          "$ref": "#/$defs/operatorLoopAction"
        },
        "inspect_progress": {
          "$ref": "#/$defs/operatorLoopAction"
        },
        "inspect_cockpit": {
          "$ref": "#/$defs/operatorLoopAction"
        },
        "build_direct_entry": {
          "$ref": "#/$defs/operatorLoopAction"
        },
        "build_submission_ready_package": {
          "$ref": "#/$defs/operatorLoopAction"
        }
      }
    },
    "repoMainline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "program_id",
        "phase_id",
        "phase_name",
        "phase_status",
        "phase_summary",
        "active_phase",
        "active_tranche",
        "next_focus"
      ],
      "properties": {
        "program_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "phase_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "phase_name": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "phase_status": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "phase_summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "active_phase": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "active_tranche": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "next_focus": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "runtimeSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_owner_line",
        "runtime_owner"
      ],
      "properties": {
        "current_owner_line": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "runtime_owner": {
          "const": "upstream_hermes_agent"
        }
      }
    },
    "productShellSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "surface_kind"
      ],
      "properties": {
        "command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "surface_kind": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "productEntryShell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_frontdesk",
        "grant_progress",
        "grant_cockpit",
        "grant_direct_entry",
        "grant_user_loop"
      ],
      "properties": {
        "product_frontdesk": {
          "$ref": "#/$defs/productShellSurface"
        },
        "grant_progress": {
          "$ref": "#/$defs/productShellSurface"
        },
        "grant_cockpit": {
          "$ref": "#/$defs/productShellSurface"
        },
        "grant_direct_entry": {
          "$ref": "#/$defs/productShellSurface"
        },
        "grant_user_loop": {
          "$ref": "#/$defs/productShellSurface"
        }
      }
    },
    "sharedHandoffBuilder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "entry_mode"
      ],
      "properties": {
        "command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "entry_mode": {
          "type": "string",
          "enum": [
            "direct",
            "opl-handoff"
          ]
        }
      }
    },
    "sharedHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direct_entry_builder",
        "opl_handoff_builder"
      ],
      "properties": {
        "direct_entry_builder": {
          "$ref": "#/$defs/sharedHandoffBuilder"
        },
        "opl_handoff_builder": {
          "$ref": "#/$defs/sharedHandoffBuilder"
        }
      }
    },
    "productEntryQuickstartStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "title",
        "command",
        "surface_kind",
        "summary",
        "requires"
      ],
      "properties": {
        "step_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "title": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "surface_kind": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "requires": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "productEntryQuickstart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "recommended_step_id",
        "summary",
        "steps",
        "resume_contract",
        "human_gate_ids"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_quickstart"
        },
        "recommended_step_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/productEntryQuickstartStep"
          }
        },
        "resume_contract": {
          "$ref": "common.schema.json#/$defs/familyResumeContract"
        },
        "human_gate_ids": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "productEntryOverviewProgressSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "command",
        "step_id"
      ],
      "properties": {
        "surface_kind": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "step_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "productEntryOverviewResumeSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "command",
        "session_locator_field",
        "checkpoint_locator_field"
      ],
      "properties": {
        "surface_kind": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "session_locator_field": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "checkpoint_locator_field": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "productEntryOverview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "summary",
        "frontdesk_command",
        "recommended_command",
        "operator_loop_command",
        "progress_surface",
        "resume_surface",
        "recommended_step_id",
        "next_focus",
        "remaining_gaps_count",
        "human_gate_ids"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_overview"
        },
        "summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "frontdesk_command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "operator_loop_command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "progress_surface": {
          "$ref": "#/$defs/productEntryOverviewProgressSurface"
        },
        "resume_surface": {
          "$ref": "#/$defs/productEntryOverviewResumeSurface"
        },
        "recommended_step_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "next_focus": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "remaining_gaps_count": {
          "type": "integer",
          "minimum": 0
        },
        "human_gate_ids": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "grantAuthoringWorkflowCoverageItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "manual_flow_label",
        "coverage_status",
        "current_surface",
        "remaining_gap"
      ],
      "properties": {
        "step_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "manual_flow_label": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "coverage_status": {
          "type": "string",
          "enum": [
            "landed_route",
            "partially_supported",
            "not_landed"
          ]
        },
        "current_surface": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "remaining_gap": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "productEntryReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "verdict",
        "usable_now",
        "good_to_use_now",
        "fully_automatic",
        "summary",
        "recommended_start_surface",
        "recommended_start_command",
        "recommended_loop_surface",
        "recommended_loop_command",
        "blocking_gaps"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_readiness"
        },
        "verdict": {
          "const": "agent_assisted_ready_not_product_grade"
        },
        "usable_now": {
          "type": "boolean"
        },
        "good_to_use_now": {
          "type": "boolean"
        },
        "fully_automatic": {
          "type": "boolean"
        },
        "summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_start_surface": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_start_command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_loop_surface": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_loop_command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "blocking_gaps": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "grantAuthoringReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "verdict",
        "fully_automatic",
        "usable_now",
        "good_to_use_now",
        "user_experience_level",
        "summary",
        "recommended_start_surface",
        "recommended_start_command",
        "recommended_loop_surface",
        "recommended_loop_command",
        "workflow_coverage",
        "blocking_gaps"
      ],
      "properties": {
        "surface_kind": {
          "const": "grant_authoring_readiness"
        },
        "verdict": {
          "const": "agent_assisted_cli_ready_not_full_autopilot"
        },
        "fully_automatic": {
          "type": "boolean"
        },
        "usable_now": {
          "type": "boolean"
        },
        "good_to_use_now": {
          "type": "boolean"
        },
        "user_experience_level": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_start_surface": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_start_command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_loop_surface": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_loop_command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "workflow_coverage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/grantAuthoringWorkflowCoverageItem"
          }
        },
        "blocking_gaps": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "productEntryStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "next_focus",
        "remaining_gaps_count"
      ],
      "properties": {
        "summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "next_focus": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "remaining_gaps_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "productEntryManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "manifest_version",
        "manifest_kind",
        "target_domain_id",
        "formal_entry",
        "workspace_locator",
        "recommended_shell",
        "recommended_command",
        "frontdesk_surface",
        "operator_loop_surface",
        "operator_loop_actions",
        "repo_mainline",
        "runtime",
        "product_entry_shell",
        "shared_handoff",
        "product_entry_overview",
        "product_entry_readiness",
        "grant_authoring_readiness",
        "product_entry_quickstart",
        "family_orchestration",
        "product_entry_status",
        "remaining_gaps",
        "notes"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_manifest"
        },
        "manifest_version": {
          "type": "integer",
          "const": 2
        },
        "manifest_kind": {
          "const": "med_auto_grant_product_entry_manifest"
        },
        "target_domain_id": {
          "const": "med-autogrant"
        },
        "formal_entry": {
          "$ref": "#/$defs/formalEntry"
        },
        "workspace_locator": {
          "$ref": "#/$defs/workspaceLocator"
        },
        "recommended_shell": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "recommended_command": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "frontdesk_surface": {
          "$ref": "#/$defs/shellSurface"
        },
        "operator_loop_surface": {
          "$ref": "#/$defs/shellSurface"
        },
        "operator_loop_actions": {
          "$ref": "#/$defs/operatorLoopActions"
        },
        "repo_mainline": {
          "$ref": "#/$defs/repoMainline"
        },
        "runtime": {
          "$ref": "#/$defs/runtimeSummary"
        },
        "product_entry_shell": {
          "$ref": "#/$defs/productEntryShell"
        },
        "shared_handoff": {
          "$ref": "#/$defs/sharedHandoff"
        },
        "product_entry_overview": {
          "$ref": "#/$defs/productEntryOverview"
        },
        "product_entry_readiness": {
          "$ref": "#/$defs/productEntryReadiness"
        },
        "grant_authoring_readiness": {
          "$ref": "#/$defs/grantAuthoringReadiness"
        },
        "product_entry_quickstart": {
          "$ref": "#/$defs/productEntryQuickstart"
        },
        "family_orchestration": {
          "$ref": "common.schema.json#/$defs/familyOrchestrationCompanion"
        },
        "product_entry_status": {
          "$ref": "#/$defs/productEntryStatus"
        },
        "remaining_gaps": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "notes": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "ok",
    "command",
    "grant_run_id",
    "workspace_id",
    "draft_id",
    "lifecycle_stage",
    "input_path",
    "product_entry_manifest"
  ],
  "properties": {
    "ok": {
      "const": true
    },
    "command": {
      "const": "product-entry-manifest"
    },
    "grant_run_id": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "workspace_id": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "draft_id": {
      "$ref": "#/$defs/nullableString"
    },
    "lifecycle_stage": {
      "$ref": "executor-routing-contract.schema.json#/$defs/authorSideRouteId"
    },
    "input_path": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "product_entry_manifest": {
      "$ref": "#/$defs/productEntryManifest"
    }
  }
}
