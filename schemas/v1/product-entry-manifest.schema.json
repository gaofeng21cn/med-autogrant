{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/product-entry-manifest.schema.json",
  "title": "Med Auto Grant Direct Handler Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "command",
    "grant_run_id",
    "workspace_id",
    "draft_id",
    "lifecycle_stage",
    "input_path",
    "product_entry_manifest"
  ],
  "properties": {
    "ok": {"const": true},
    "command": {"const": "product-entry-manifest"},
    "grant_run_id": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "workspace_id": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "draft_id": {"type": ["string", "null"]},
    "lifecycle_stage": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "input_path": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "product_entry_manifest": {"$ref": "#/$defs/productEntryManifest"}
  },
  "$defs": {
    "productEntryManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_version",
        "manifest_kind",
        "target_domain_id",
        "formal_entry",
        "workspace_locator",
        "runtime",
        "repo_mainline",
        "product_entry_status",
        "product_entry_shell",
        "operator_loop_actions",
        "progress_projection",
        "family_action_catalog",
        "family_stage_control_plane",
        "grant_transition_oracle",
        "domain_entry_contract",
        "skill_catalog",
        "product_entry_start",
        "owner_receipt_contract",
        "minimal_authority_functions",
        "authority_boundary",
        "notes"
      ],
      "properties": {
        "manifest_version": {"const": 2},
        "manifest_kind": {"const": "med_auto_grant_product_entry_manifest"},
        "target_domain_id": {"const": "med-autogrant"},
        "formal_entry": {"type": "object"},
        "workspace_locator": {
          "type": "object",
          "required": ["workspace_surface_kind", "workspace_path"],
          "properties": {
            "workspace_surface_kind": {"const": "nsfc_workspace"},
            "workspace_path": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
          }
        },
        "runtime": {"type": "object"},
        "repo_mainline": {"type": "object"},
        "product_entry_status": {"type": "object"},
        "product_entry_shell": {
          "type": "object",
          "required": ["product_status", "grant_progress", "grant_cockpit", "grant_direct_entry", "grant_user_loop"],
          "additionalProperties": {"$ref": "#/$defs/shellSurface"}
        },
        "operator_loop_actions": {"type": "object"},
        "progress_projection": {"type": "object"},
        "family_action_catalog": {"type": "object"},
        "family_stage_control_plane": {"type": "object"},
        "grant_transition_oracle": {"type": "object"},
        "domain_entry_contract": {"type": "object"},
        "skill_catalog": {"type": "object"},
        "product_entry_start": {"type": "object"},
        "owner_receipt_contract": {"type": "object"},
        "minimal_authority_functions": {"type": "array", "items": {"type": "object"}},
        "authority_boundary": {"type": "object"},
        "notes": {"$ref": "common.schema.json#/$defs/stringList"}
      }
    },
    "shellSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "surface_kind"],
      "properties": {
        "command": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
        "surface_kind": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
      }
    }
  }
}
