{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/hosted-contract-bundle.schema.json",
  "title": "Med Auto Grant Hosted Contract Bundle",
  "type": "object",
  "$defs": {
    "formalEntryMatrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_formal_entry",
        "supported_protocol_layer",
        "internal_controller_surface"
      ],
      "properties": {
        "default_formal_entry": {
          "const": "CLI"
        },
        "supported_protocol_layer": {
          "const": "MCP"
        },
        "internal_controller_surface": {
          "const": "controller"
        }
      }
    },
    "executionIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grant_run_id",
        "workspace_id",
        "draft_id",
        "program_id"
      ],
      "properties": {
        "grant_run_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "workspace_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "draft_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "program_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "sessionContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_handle_kind",
        "session_owner",
        "generated_session_surface_ref",
        "generated_resume_surface_ref",
        "domain_authority_surface_ref",
        "required_mag_authority_surfaces"
      ],
      "properties": {
        "session_handle_kind": {
          "const": "grant_run_id"
        },
        "session_owner": {
          "const": "one-person-lab"
        },
        "generated_session_surface_ref": {
          "const": "opl://generated-surfaces/mag/product-entry-session"
        },
        "generated_resume_surface_ref": {
          "const": "opl://generated-surfaces/mag/product-entry-session#resume"
        },
        "domain_authority_surface_ref": {
          "const": "/product_entry_manifest/owner_receipt_contract"
        },
        "required_mag_authority_surfaces": {
          "const": [
            "build-artifact-bundle",
            "build-final-package",
            "build-submission-ready-package",
            "owner_receipt_contract",
            "grant_transition_oracle"
          ]
        }
      }
    },
    "stateContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_surface_kind",
        "run_journal_kind",
        "stage_action_envelope_kind",
        "artifact_bundle_kind",
        "final_package_kind"
      ],
      "properties": {
        "workspace_surface_kind": {
          "const": "nsfc_workspace"
        },
        "run_journal_kind": {
          "const": "local_run_journal"
        },
        "stage_action_envelope_kind": {
          "const": "stage_action_envelope"
        },
        "artifact_bundle_kind": {
          "const": "artifact_bundle"
        },
        "final_package_kind": {
          "const": "final_package"
        }
      }
    },
    "artifactContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_bundle_manifest_kind",
        "final_package_manifest_kind",
        "lineage_fields"
      ],
      "properties": {
        "artifact_bundle_manifest_kind": {
          "const": "artifact_bundle_manifest"
        },
        "final_package_manifest_kind": {
          "const": "freeze_manifest"
        },
        "lineage_fields": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/nonEmptyString"
          },
          "minItems": 6
        }
      }
    },
    "auditContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_checkpoint_kind",
        "checkpoint_status_kind",
        "reviewed_revision_evidence_kind"
      ],
      "properties": {
        "verification_checkpoint_kind": {
          "const": "verification_checkpoint"
        },
        "checkpoint_status_kind": {
          "const": "checkpoint_status"
        },
        "reviewed_revision_evidence_kind": {
          "const": "reviewed_revision_evidence"
        }
      }
    },
    "domainEntryContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_adapter",
        "service_safe_surface_kind",
        "product_entry_builder_command",
        "product_entry_kind",
        "supported_entry_modes",
        "domain_agent_entry_spec",
        "supported_commands",
        "command_contracts"
      ],
      "properties": {
        "entry_adapter": {
          "const": "MedAutoGrantDomainEntry"
        },
        "service_safe_surface_kind": {
          "const": "service-safe-domain-entry-command"
        },
        "product_entry_builder_command": {
          "const": "product build-entry"
        },
        "product_entry_kind": {
          "const": "med_auto_grant_product_entry"
        },
        "supported_entry_modes": {
          "const": [
            "direct",
            "opl-handoff"
          ]
        },
        "domain_agent_entry_spec": {
          "$ref": "product-entry.schema.json#/$defs/domainAgentEntrySpec"
        },
        "supported_commands": {
          "const": [
            "validate-workspace",
            "summarize-workspace",
            "grant-intake-audit",
            "grant-evidence-grounding",
            "grant-quality-scorecard",
            "grant-quality-closure-dossier",
            "grant-quality-diff",
            "discover-funding-opportunities",
            "refresh-funding-opportunities-cache",
            "select-project-profile",
            "initialize-intake-workspace",
            "next-step",
            "critique-summary",
            "stage-route-report",
            "execute-direction-screening-pass",
            "execute-question-refinement-pass",
            "execute-argument-building-pass",
            "execute-fit-alignment-pass",
            "execute-outline-pass",
            "execute-drafting-pass",
            "build-artifact-bundle",
            "execute-critique-pass",
            "execute-critique-revision-loop",
            "execute-authoring-mainline-loop",
            "execute-grant-autonomy-controller",
            "execute-revision-pass",
            "execute-freeze-pass",
            "build-final-package",
            "build-hosted-contract-bundle",
            "build-submission-ready-package"
          ]
        },
        "command_contracts": {
          "type": "array",
          "items": {
            "$ref": "product-entry.schema.json#/$defs/domainEntryCommandContract"
          },
          "minItems": 29
        }
      }
    },
    "schemaContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "schema_index_path",
        "aggregate_root_schema",
        "contract_schema_files"
      ],
      "properties": {
        "schema_version": {
          "const": "v1"
        },
        "schema_index_path": {
          "const": "schemas/v1/schema-index.json"
        },
        "aggregate_root_schema": {
          "const": "nsfc-workspace.schema.json"
        },
        "contract_schema_files": {
          "const": [
            "service-safe-domain-surface.schema.json",
            "executor-routing-contract.schema.json",
            "product-entry.schema.json",
            "grant-intake-audit.schema.json",
            "grant-evidence-grounding.schema.json",
            "grant-quality-scorecard.schema.json",
            "grant-quality-closure-dossier.schema.json",
            "grant-quality-diff.schema.json",
            "grant-autonomy-controller-input.schema.json",
            "grant-autonomy-controller-report.schema.json",
            "funding-landscape-discovery-input.schema.json",
            "funding-landscape-discovery.schema.json",
            "funding-landscape-cache.schema.json",
            "funding-landscape-diff-report.schema.json",
            "project-profile-selection-input.schema.json",
            "project-profile-selection.schema.json",
            "critique-loop-report.schema.json",
            "authoring-mainline-loop-report.schema.json",
            "hosted-contract-bundle.schema.json",
            "submission-ready-package.schema.json"
          ]
        }
      }
    },
    "authoringContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_contract_version",
        "route_catalog_kind",
        "author_side_route_catalog"
      ],
      "properties": {
        "route_contract_version": {
          "type": "integer",
          "const": 1
        },
        "route_catalog_kind": {
          "const": "author_side_route_catalog"
        },
        "author_side_route_catalog": {
          "type": "array",
          "items": {
            "$ref": "executor-routing-contract.schema.json#/$defs/routeContract"
          },
          "minItems": 12
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "contract_version",
    "bundle_kind",
    "formal_entry_matrix",
    "execution_identity",
    "runtime_substrate_contract",
    "runtime_state_contract",
    "session_contract",
    "operator_contract",
    "state_contract",
    "artifact_contract",
    "audit_contract",
    "domain_entry_contract",
    "schema_contract",
    "authoring_contract"
  ],
  "properties": {
    "contract_version": {
      "type": "integer",
      "const": 1
    },
    "bundle_kind": {
      "const": "hosted_contract_bundle"
    },
    "formal_entry_matrix": {
      "$ref": "#/$defs/formalEntryMatrix"
    },
    "execution_identity": {
      "$ref": "#/$defs/executionIdentity"
    },
    "runtime_substrate_contract": {
      "$ref": "product-entry.schema.json#/$defs/runtimeSubstrateContract"
    },
    "runtime_state_contract": {
      "$ref": "product-entry.schema.json#/$defs/runtimeStateContract"
    },
    "session_contract": {
      "$ref": "#/$defs/sessionContract"
    },
    "operator_contract": {
      "$ref": "product-entry.schema.json#/$defs/operatorContract"
    },
    "state_contract": {
      "$ref": "#/$defs/stateContract"
    },
    "artifact_contract": {
      "$ref": "#/$defs/artifactContract"
    },
    "audit_contract": {
      "$ref": "#/$defs/auditContract"
    },
    "domain_entry_contract": {
      "$ref": "#/$defs/domainEntryContract"
    },
    "schema_contract": {
      "$ref": "#/$defs/schemaContract"
    },
    "authoring_contract": {
      "$ref": "#/$defs/authoringContract"
    }
  }
}
