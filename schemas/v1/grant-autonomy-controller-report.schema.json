{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/grant-autonomy-controller-report.schema.json",
  "title": "GrantAutonomyControllerReport",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "stringQueue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "uniqueItems": true
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_status",
        "summary"
      ],
      "properties": {
        "target_status": {
          "type": "string",
          "enum": [
            "submission_grade_candidate",
            "near_submission_candidate"
          ]
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "budgetUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_total_steps",
        "spent_steps",
        "remaining_steps",
        "exhausted"
      ],
      "properties": {
        "max_total_steps": {
          "type": "integer",
          "minimum": 0
        },
        "spent_steps": {
          "type": "integer",
          "minimum": 0
        },
        "remaining_steps": {
          "type": "integer",
          "minimum": 0
        },
        "exhausted": {
          "type": "boolean"
        }
      }
    },
    "blockerReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_blocker_queue",
        "initial_evidence_gap_queue",
        "latest_quality_blocker_report",
        "unresolved_blocker_count",
        "evidence_gap_count"
      ],
      "properties": {
        "initial_blocker_queue": {
          "$ref": "#/$defs/stringQueue"
        },
        "initial_evidence_gap_queue": {
          "$ref": "#/$defs/stringQueue"
        },
        "latest_quality_blocker_report": {
          "type": "object"
        },
        "unresolved_blocker_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_gap_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "traceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_action",
        "cycle",
        "step_index",
        "result"
      ],
      "properties": {
        "step_action": {
          "type": "string",
          "enum": [
            "discoverer",
            "selector",
            "initializer",
            "quality_evaluator",
            "mainline_runner"
          ]
        },
        "cycle": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "step_index": {
          "type": "integer",
          "minimum": 1
        },
        "result": {
          "type": "string",
          "enum": [
            "executed"
          ]
        }
      }
    },
    "decisionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cycle",
        "action",
        "accepted",
        "reason"
      ],
      "properties": {
        "cycle": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "type": "string",
          "enum": [
            "reselect",
            "rollback"
          ]
        },
        "accepted": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "qualityStatus": {
      "type": "string",
      "enum": [
        "submission_grade_candidate",
        "near_submission_candidate",
        "not_ready",
        "unknown"
      ]
    },
    "controllerAction": {
      "type": "string",
      "enum": [
        "continue_mainline",
        "stop_success",
        "rollback_upstream",
        "reselect_project_profile",
        "fail_closed"
      ]
    },
    "nullableControllerAction": {
      "anyOf": [
        {
          "$ref": "#/$defs/controllerAction"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableQualitySummary": {
      "anyOf": [
        {
          "$ref": "grant-quality-closure-dossier.schema.json#/$defs/qualitySummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableClosurePackage": {
      "anyOf": [
        {
          "$ref": "grant-quality-closure-dossier.schema.json#/$defs/closurePackage"
        },
        {
          "type": "null"
        }
      ]
    },
    "controllerCheckpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "resume_start_mode",
        "workspace_id",
        "completed_cycles",
        "next_controller_action"
      ],
      "properties": {
        "checkpoint_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "resume_start_mode": {
          "const": "controller_report"
        },
        "workspace_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "completed_cycles": {
          "type": "integer",
          "minimum": 0
        },
        "next_controller_action": {
          "$ref": "#/$defs/controllerAction"
        }
      }
    },
    "controllerExecutionBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "execution_scope",
        "mag_role",
        "post_start_residency_owner",
        "attempt_ledger_owner",
        "stage_transition_authority",
        "controller_status_role",
        "max_domain_cycles_per_invocation",
        "mag_long_running_driver",
        "mag_scheduler_daemon_owner",
        "mag_owns_attempt_ledger",
        "mag_writes_stage_current_pointer",
        "mag_writes_stage_terminal_state",
        "mag_selects_next_opl_stage",
        "requires_opl_stage_transition_authority"
      ],
      "properties": {
        "surface_kind": {
          "const": "mag_autonomy_controller_execution_boundary"
        },
        "execution_scope": {
          "const": "bounded_single_opl_provider_attempt"
        },
        "mag_role": {
          "const": "refs_only_domain_authority_action_target"
        },
        "post_start_residency_owner": {
          "const": "one-person-lab"
        },
        "attempt_ledger_owner": {
          "const": "one-person-lab"
        },
        "stage_transition_authority": {
          "const": "one-person-lab"
        },
        "controller_status_role": {
          "const": "mag_domain_controller_result_not_opl_stage_terminal"
        },
        "max_domain_cycles_per_invocation": {
          "type": "integer",
          "const": 1
        },
        "mag_long_running_driver": {
          "const": false
        },
        "mag_scheduler_daemon_owner": {
          "const": false
        },
        "mag_owns_attempt_ledger": {
          "const": false
        },
        "mag_writes_stage_current_pointer": {
          "const": false
        },
        "mag_writes_stage_terminal_state": {
          "const": false
        },
        "mag_selects_next_opl_stage": {
          "const": false
        },
        "requires_opl_stage_transition_authority": {
          "const": true
        }
      }
    },
    "authorityReturn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "allowed_return_shapes",
        "result_shape",
        "body_policy",
        "refs",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "mag_autonomy_controller_authority_return"
        },
        "allowed_return_shapes": {
          "type": "array",
          "items": {
            "enum": [
              "domain_owner_receipt",
              "typed_blocker",
              "no_regression_evidence"
            ]
          },
          "minItems": 3,
          "maxItems": 3
        },
        "result_shape": {
          "enum": [
            "typed_blocker",
            "no_regression_evidence"
          ]
        },
        "body_policy": {
          "const": "refs_only_no_runtime_or_grant_body"
        },
        "refs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "minProperties": 1
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mag_writes_opl_attempt_ledger",
            "mag_runs_scheduler_daemon",
            "mag_returns_runtime_or_grant_body",
            "stage_transition_authority",
            "controller_status_role",
            "mag_writes_stage_current_pointer",
            "mag_writes_stage_terminal_state",
            "mag_selects_next_opl_stage",
            "requires_opl_stage_transition_authority"
          ],
          "properties": {
            "mag_writes_opl_attempt_ledger": {
              "const": false
            },
            "mag_runs_scheduler_daemon": {
              "const": false
            },
            "mag_returns_runtime_or_grant_body": {
              "const": false
            },
            "stage_transition_authority": {
              "const": "one-person-lab"
            },
            "controller_status_role": {
              "const": "mag_domain_controller_result_not_opl_stage_terminal"
            },
            "mag_writes_stage_current_pointer": {
              "const": false
            },
            "mag_writes_stage_terminal_state": {
              "const": false
            },
            "mag_selects_next_opl_stage": {
              "const": false
            },
            "requires_opl_stage_transition_authority": {
              "const": true
            }
          }
        }
      }
    },
    "gateStatus": {
      "type": "string",
      "enum": [
        "open",
        "passed",
        "blocked",
        "failed_closed"
      ]
    },
    "trancheSuccessGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_status",
        "requires_zero_blockers",
        "requires_zero_evidence_gaps"
      ],
      "properties": {
        "target_status": {
          "type": "string",
          "enum": [
            "submission_grade_candidate",
            "near_submission_candidate"
          ]
        },
        "requires_zero_blockers": {
          "type": "boolean"
        },
        "requires_zero_evidence_gaps": {
          "type": "boolean"
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "controllerDecisionBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cycle",
        "gate_status",
        "quality_status",
        "unresolved_blockers",
        "evidence_gaps",
        "quality_summary",
        "closure_package_queue_ids",
        "active_closure_package_id",
        "active_closure_package_action",
        "active_closure_package_target_stage",
        "decision_reason",
        "termination_reason"
      ],
      "properties": {
        "cycle": {
          "type": "integer",
          "minimum": 0
        },
        "gate_status": {
          "$ref": "#/$defs/gateStatus"
        },
        "quality_status": {
          "$ref": "#/$defs/qualityStatus"
        },
        "unresolved_blockers": {
          "$ref": "#/$defs/stringQueue"
        },
        "evidence_gaps": {
          "$ref": "#/$defs/stringQueue"
        },
        "quality_summary": {
          "$ref": "#/$defs/nullableQualitySummary"
        },
        "closure_package_queue_ids": {
          "$ref": "#/$defs/stringQueue"
        },
        "active_closure_package_id": {
          "$ref": "grant-quality-closure-dossier.schema.json#/$defs/nullableString"
        },
        "active_closure_package_action": {
          "$ref": "#/$defs/nullableControllerAction"
        },
        "active_closure_package_target_stage": {
          "$ref": "grant-quality-closure-dossier.schema.json#/$defs/nullableString"
        },
        "decision_reason": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "termination_reason": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "controllerPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_tranche",
        "tranche_objective",
        "tranche_success_gate",
        "quality_summary",
        "closure_package_queue_ids",
        "active_closure_package_id",
        "active_closure_package_action",
        "active_closure_package_target_stage",
        "next_controller_action",
        "decision_basis"
      ],
      "properties": {
        "current_tranche": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tranche_objective": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tranche_success_gate": {
          "$ref": "#/$defs/trancheSuccessGate"
        },
        "quality_summary": {
          "$ref": "#/$defs/nullableQualitySummary"
        },
        "closure_package_queue_ids": {
          "$ref": "#/$defs/stringQueue"
        },
        "active_closure_package_id": {
          "$ref": "grant-quality-closure-dossier.schema.json#/$defs/nullableString"
        },
        "active_closure_package_action": {
          "$ref": "#/$defs/nullableControllerAction"
        },
        "active_closure_package_target_stage": {
          "$ref": "grant-quality-closure-dossier.schema.json#/$defs/nullableString"
        },
        "next_controller_action": {
          "$ref": "#/$defs/controllerAction"
        },
        "decision_basis": {
          "$ref": "#/$defs/controllerDecisionBasis"
        }
      }
    },
    "trancheHistoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cycle",
        "current_tranche",
        "tranche_objective",
        "tranche_success_gate",
        "gate_status",
        "next_controller_action",
        "decision_reason",
        "quality_status",
        "unresolved_blockers",
        "evidence_gaps",
        "quality_summary",
        "closure_package_queue_ids",
        "active_closure_package_id",
        "active_closure_package_action",
        "active_closure_package_target_stage",
        "termination_reason"
      ],
      "properties": {
        "cycle": {
          "type": "integer",
          "minimum": 1
        },
        "current_tranche": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tranche_objective": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tranche_success_gate": {
          "$ref": "#/$defs/trancheSuccessGate"
        },
        "gate_status": {
          "$ref": "#/$defs/gateStatus"
        },
        "next_controller_action": {
          "$ref": "#/$defs/controllerAction"
        },
        "decision_reason": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "quality_status": {
          "$ref": "#/$defs/qualityStatus"
        },
        "unresolved_blockers": {
          "$ref": "#/$defs/stringQueue"
        },
        "evidence_gaps": {
          "$ref": "#/$defs/stringQueue"
        },
        "quality_summary": {
          "$ref": "#/$defs/nullableQualitySummary"
        },
        "closure_package_queue_ids": {
          "$ref": "#/$defs/stringQueue"
        },
        "active_closure_package_id": {
          "$ref": "grant-quality-closure-dossier.schema.json#/$defs/nullableString"
        },
        "active_closure_package_action": {
          "$ref": "#/$defs/nullableControllerAction"
        },
        "active_closure_package_target_stage": {
          "$ref": "grant-quality-closure-dossier.schema.json#/$defs/nullableString"
        },
        "termination_reason": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  },
  "required": [
    "surface_kind",
    "controller_version",
    "controller_checkpoint",
    "request_id",
    "controller_status",
    "termination_reason",
    "started_from_mode",
    "goal",
    "completed_cycles",
    "max_rounds_or_cycles",
    "budget",
    "blocker_report",
    "unresolved_blockers",
    "evidence_gaps",
    "action_trace",
    "reselection_decisions",
    "rollback_decisions",
    "latest_quality_closure_dossier",
    "closure_package_queue",
    "active_closure_package",
    "controller_plan",
    "tranche_history",
    "final_workspace",
    "controller_execution_boundary",
    "authority_return"
  ],
  "properties": {
    "surface_kind": {
      "const": "grant_autonomy_controller_report"
    },
    "controller_version": {
      "type": "integer",
      "const": 3
    },
    "controller_checkpoint": {
      "$ref": "#/$defs/controllerCheckpoint"
    },
    "request_id": {
      "type": "string"
    },
    "controller_status": {
      "type": "string",
      "enum": [
        "submission_grade_candidate",
        "near_submission_candidate",
        "failed_closed"
      ]
    },
    "termination_reason": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "started_from_mode": {
      "type": "string",
      "enum": [
        "selection_input",
        "workspace",
        "discovery_input",
        "controller_report",
        "unknown"
      ]
    },
    "goal": {
      "$ref": "#/$defs/goal"
    },
    "completed_cycles": {
      "type": "integer",
      "minimum": 0
    },
    "max_rounds_or_cycles": {
      "type": "integer",
      "minimum": 0
    },
    "budget": {
      "$ref": "#/$defs/budgetUsage"
    },
    "blocker_report": {
      "$ref": "#/$defs/blockerReport"
    },
    "unresolved_blockers": {
      "$ref": "#/$defs/stringQueue"
    },
    "evidence_gaps": {
      "$ref": "#/$defs/stringQueue"
    },
    "action_trace": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/traceEntry"
      }
    },
    "reselection_decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decisionEntry"
      }
    },
    "rollback_decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decisionEntry"
      }
    },
    "latest_quality_closure_dossier": {
      "anyOf": [
        {
          "$ref": "grant-quality-closure-dossier.schema.json#/$defs/grantQualityClosureDossier"
        },
        {
          "type": "null"
        }
      ]
    },
    "closure_package_queue": {
      "type": "array",
      "items": {
        "$ref": "grant-quality-closure-dossier.schema.json#/$defs/closurePackage"
      }
    },
    "active_closure_package": {
      "$ref": "#/$defs/nullableClosurePackage"
    },
    "controller_plan": {
      "$ref": "#/$defs/controllerPlan"
    },
    "tranche_history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trancheHistoryEntry"
      }
    },
    "final_workspace": {
      "type": "object"
    },
    "controller_execution_boundary": {
      "$ref": "#/$defs/controllerExecutionBoundary"
    },
    "authority_return": {
      "$ref": "#/$defs/authorityReturn"
    }
  }
}
