{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/grant-autonomy-controller-report.schema.json",
  "title": "GrantAutonomyControllerReport",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "stringQueue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "uniqueItems": true
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_status",
        "summary"
      ],
      "properties": {
        "target_status": {
          "type": "string",
          "enum": [
            "submission_grade_candidate",
            "near_submission_candidate"
          ]
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "budgetUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_total_steps",
        "spent_steps",
        "remaining_steps",
        "exhausted"
      ],
      "properties": {
        "max_total_steps": {
          "type": "integer",
          "minimum": 0
        },
        "spent_steps": {
          "type": "integer",
          "minimum": 0
        },
        "remaining_steps": {
          "type": "integer",
          "minimum": 0
        },
        "exhausted": {
          "type": "boolean"
        }
      }
    },
    "blockerReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_blocker_queue",
        "initial_evidence_gap_queue",
        "latest_quality_blocker_report",
        "unresolved_blocker_count",
        "evidence_gap_count"
      ],
      "properties": {
        "initial_blocker_queue": {
          "$ref": "#/$defs/stringQueue"
        },
        "initial_evidence_gap_queue": {
          "$ref": "#/$defs/stringQueue"
        },
        "latest_quality_blocker_report": {
          "type": "object"
        },
        "unresolved_blocker_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_gap_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "traceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_action",
        "cycle",
        "step_index",
        "result"
      ],
      "properties": {
        "step_action": {
          "type": "string",
          "enum": [
            "discoverer",
            "selector",
            "initializer",
            "quality_evaluator",
            "mainline_runner"
          ]
        },
        "cycle": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "step_index": {
          "type": "integer",
          "minimum": 1
        },
        "result": {
          "type": "string",
          "enum": [
            "executed"
          ]
        }
      }
    },
    "decisionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cycle",
        "action",
        "accepted",
        "reason"
      ],
      "properties": {
        "cycle": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "type": "string",
          "enum": [
            "reselect",
            "rollback"
          ]
        },
        "accepted": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "surface_kind",
    "controller_version",
    "request_id",
    "controller_status",
    "termination_reason",
    "started_from_mode",
    "goal",
    "completed_cycles",
    "max_rounds_or_cycles",
    "budget",
    "blocker_report",
    "unresolved_blockers",
    "evidence_gaps",
    "action_trace",
    "reselection_decisions",
    "rollback_decisions",
    "final_workspace"
  ],
  "properties": {
    "surface_kind": {
      "const": "grant_autonomy_controller_report"
    },
    "controller_version": {
      "type": "integer",
      "const": 1
    },
    "request_id": {
      "type": "string"
    },
    "controller_status": {
      "type": "string",
      "enum": [
        "submission_grade_candidate",
        "near_submission_candidate",
        "failed_closed"
      ]
    },
    "termination_reason": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "started_from_mode": {
      "type": "string",
      "enum": [
        "selection_input",
        "workspace",
        "discovery_input",
        "unknown"
      ]
    },
    "goal": {
      "$ref": "#/$defs/goal"
    },
    "completed_cycles": {
      "type": "integer",
      "minimum": 0
    },
    "max_rounds_or_cycles": {
      "type": "integer",
      "minimum": 0
    },
    "budget": {
      "$ref": "#/$defs/budgetUsage"
    },
    "blocker_report": {
      "$ref": "#/$defs/blockerReport"
    },
    "unresolved_blockers": {
      "$ref": "#/$defs/stringQueue"
    },
    "evidence_gaps": {
      "$ref": "#/$defs/stringQueue"
    },
    "action_trace": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/traceEntry"
      }
    },
    "reselection_decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decisionEntry"
      }
    },
    "rollback_decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decisionEntry"
      }
    },
    "final_workspace": {
      "type": "object"
    }
  }
}
