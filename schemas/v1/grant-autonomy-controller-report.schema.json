{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/grant-autonomy-controller-report.schema.json",
  "title": "Grant Autonomy OPL Handoff Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "controller_version",
    "request_id",
    "controller_status",
    "termination_reason",
    "started_from_mode",
    "goal",
    "completed_cycles",
    "unresolved_blockers",
    "evidence_gaps",
    "final_workspace",
    "controller_execution_boundary",
    "authority_return"
  ],
  "properties": {
    "surface_kind": {"const": "grant_autonomy_controller_report"},
    "controller_version": {"const": 4},
    "request_id": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "controller_status": {"const": "failed_closed"},
    "termination_reason": {
      "enum": ["opl_provider_attempt_required", "opl_runtime_controller_required"]
    },
    "started_from_mode": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "goal": {"type": "object"},
    "completed_cycles": {"const": 0},
    "unresolved_blockers": {"$ref": "common.schema.json#/$defs/stringList"},
    "evidence_gaps": {"$ref": "common.schema.json#/$defs/stringList"},
    "final_workspace": {"type": "object", "maxProperties": 0},
    "controller_execution_boundary": {"type": "object"},
    "authority_return": {"type": "object"}
  }
}
