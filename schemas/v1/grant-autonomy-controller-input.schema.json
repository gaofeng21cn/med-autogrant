{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/grant-autonomy-controller-input.schema.json",
  "title": "Grant Autonomy OPL Handoff Input",
  "type": "object",
  "required": ["request_id", "start", "goal"],
  "properties": {
    "request_id": {"$ref": "common.schema.json#/$defs/nonEmptyString"},
    "start": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {"$ref": "common.schema.json#/$defs/nonEmptyString"}
      }
    },
    "goal": {"type": "object"},
    "opl_stage_attempt": {"type": "object"}
  }
}
