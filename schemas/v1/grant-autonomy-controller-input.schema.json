{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/grant-autonomy-controller-input.schema.json",
  "title": "GrantAutonomyControllerInput",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "stringQueue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "uniqueItems": true
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_status",
        "summary"
      ],
      "properties": {
        "target_status": {
          "type": "string",
          "enum": [
            "submission_grade_candidate",
            "near_submission_candidate"
          ]
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_total_steps"
      ],
      "properties": {
        "max_total_steps": {
          "type": "integer",
          "minimum": 1
        },
        "budget_notes": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "stopConditions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_zero_blockers",
        "require_zero_evidence_gaps"
      ],
      "properties": {
        "require_zero_blockers": {
          "type": "boolean"
        },
        "require_zero_evidence_gaps": {
          "type": "boolean"
        }
      }
    },
    "reselectionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "max_reselections"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "max_reselections": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rollbackPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "max_rollbacks"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "max_rollbacks": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "controllerPlanSuccessGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_status",
        "requires_zero_blockers",
        "requires_zero_evidence_gaps"
      ],
      "properties": {
        "target_status": {
          "type": "string",
          "enum": [
            "submission_grade_candidate",
            "near_submission_candidate"
          ]
        },
        "requires_zero_blockers": {
          "type": "boolean"
        },
        "requires_zero_evidence_gaps": {
          "type": "boolean"
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "controllerPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_tranche",
        "tranche_objective",
        "tranche_success_gate"
      ],
      "properties": {
        "current_tranche": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tranche_objective": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tranche_success_gate": {
          "$ref": "#/$defs/controllerPlanSuccessGate"
        }
      }
    },
    "selectionInputStart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "selection_input"
      ],
      "properties": {
        "mode": {
          "const": "selection_input"
        },
        "selection_input": {
          "$ref": "project-profile-selection-input.schema.json"
        }
      }
    },
    "workspaceStart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "workspace"
      ],
      "properties": {
        "mode": {
          "const": "workspace"
        },
        "workspace": {
          "$ref": "nsfc-workspace.schema.json"
        }
      }
    },
    "discoveryInputStart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "discovery_input"
      ],
      "properties": {
        "mode": {
          "const": "discovery_input"
        },
        "discovery_input": {
          "$ref": "funding-landscape-discovery-input.schema.json"
        }
      }
    },
    "controllerReportStart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "controller_report"
      ],
      "properties": {
        "mode": {
          "const": "controller_report"
        },
        "controller_report": {
          "$ref": "grant-autonomy-controller-report.schema.json"
        }
      }
    },
    "oplStageAttempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_owner",
        "executor_kind"
      ],
      "anyOf": [
        {
          "required": [
            "attempt_lease_ref"
          ]
        },
        {
          "required": [
            "stage_attempt_receipt_ref"
          ]
        },
        {
          "required": [
            "receipt_ref"
          ]
        },
        {
          "required": [
            "lease_ref"
          ]
        }
      ],
      "properties": {
        "runtime_owner": {
          "const": "one-person-lab"
        },
        "executor_kind": {
          "const": "codex_cli"
        },
        "attempt_lease_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "stage_attempt_receipt_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "receipt_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "lease_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  },
  "required": [
    "request_id",
    "start",
    "goal",
    "max_rounds_or_cycles",
    "budget",
    "stop_conditions",
    "blocker_queue",
    "evidence_gap_queue",
    "reselection_policy",
    "rollback_policy"
  ],
  "properties": {
    "request_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "opl_stage_attempt": {
      "$ref": "#/$defs/oplStageAttempt"
    },
    "start": {
      "oneOf": [
        {
          "$ref": "#/$defs/selectionInputStart"
        },
        {
          "$ref": "#/$defs/workspaceStart"
        },
        {
          "$ref": "#/$defs/discoveryInputStart"
        },
        {
          "$ref": "#/$defs/controllerReportStart"
        }
      ]
    },
    "goal": {
      "$ref": "#/$defs/goal"
    },
    "max_rounds_or_cycles": {
      "type": "integer",
      "minimum": 1
    },
    "budget": {
      "$ref": "#/$defs/budget"
    },
    "stop_conditions": {
      "$ref": "#/$defs/stopConditions"
    },
    "blocker_queue": {
      "$ref": "#/$defs/stringQueue"
    },
    "evidence_gap_queue": {
      "$ref": "#/$defs/stringQueue"
    },
    "reselection_policy": {
      "$ref": "#/$defs/reselectionPolicy"
    },
    "rollback_policy": {
      "$ref": "#/$defs/rollbackPolicy"
    },
    "controller_plan": {
      "$ref": "#/$defs/controllerPlan"
    }
  }
}
