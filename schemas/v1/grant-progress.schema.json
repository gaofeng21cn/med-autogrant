{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/grant-progress.schema.json",
  "title": "Med Auto Grant Progress Projection",
  "type": "object",
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "focusPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicant_name",
        "funding_program",
        "project_profile_label",
        "template_label",
        "critique_policy_id",
        "selected_direction_title",
        "selected_question",
        "active_draft_title",
        "critique_verdict"
      ],
      "properties": {
        "applicant_name": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "funding_program": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "project_profile_label": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "template_label": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "critique_policy_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "selected_direction_title": {
          "$ref": "#/$defs/nullableString"
        },
        "selected_question": {
          "$ref": "#/$defs/nullableString"
        },
        "active_draft_title": {
          "$ref": "#/$defs/nullableString"
        },
        "critique_verdict": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "productEntrySurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "builder_command",
        "target_domain_id",
        "supported_entry_modes",
        "task_intent_required",
        "workspace_path"
      ],
      "properties": {
        "builder_command": {
          "const": "opl://generated-surfaces/mag/product-entry-session"
        },
        "target_domain_id": {
          "const": "med-autogrant"
        },
        "supported_entry_modes": {
          "const": [
            "direct",
            "opl-handoff"
          ]
        },
        "task_intent_required": {
          "const": true
        },
        "workspace_path": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "currentnessResolver": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "version",
        "target_domain_id",
        "current_program",
        "workspace_truth",
        "last_receipt_or_blocker",
        "stage_refs",
        "manifest_refs",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "mag_progress_first_currentness_resolver"
        },
        "version": {
          "const": "mag-progress-currentness.v1"
        },
        "target_domain_id": {
          "const": "med-autogrant"
        },
        "current_program": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "program_id",
            "ref"
          ],
          "properties": {
            "program_id": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "ref": {
              "const": "contracts/runtime-program/current-program.json"
            }
          }
        },
        "workspace_truth": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "workspace_path",
            "workspace_id",
            "grant_run_id",
            "lifecycle_stage",
            "checkpoint_status"
          ],
          "properties": {
            "workspace_path": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "workspace_id": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "grant_run_id": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "lifecycle_stage": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "checkpoint_status": {
              "$ref": "product-entry.schema.json#/$defs/checkpointStatus"
            }
          }
        },
        "last_receipt_or_blocker": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "owner",
            "ref",
            "required_return_shapes",
            "body_free_payload_required"
          ],
          "properties": {
            "owner": {
              "const": "med-autogrant"
            },
            "ref": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "required_return_shapes": {
              "type": "array",
              "items": {
                "$ref": "common.schema.json#/$defs/nonEmptyString"
              }
            },
            "body_free_payload_required": {
              "const": true
            }
          }
        },
        "stage_refs": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "stage_control_plane_ref",
            "current_stage",
            "recommended_next_stage",
            "domain_stage_refs"
          ],
          "properties": {
            "stage_control_plane_ref": {
              "const": "/product_entry_manifest/family_stage_control_plane"
            },
            "current_stage": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "recommended_next_stage": {
              "$ref": "common.schema.json#/$defs/nonEmptyString"
            },
            "domain_stage_refs": {
              "type": "array",
              "items": {
                "$ref": "common.schema.json#/$defs/nonEmptyString"
              }
            }
          }
        },
        "manifest_refs": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "progress_projection_ref",
            "product_entry_manifest_ref"
          ],
          "properties": {
            "progress_projection_ref": {
              "const": "/product_entry_manifest/progress_projection"
            },
            "product_entry_manifest_ref": {
              "const": "/product_entry_manifest"
            }
          }
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "oplProgressDelta": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "version",
        "progress_delta_classification",
        "deliverable_progress_delta",
        "platform_repair_delta",
        "next_forced_delta"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_progress_first_delta_mapping"
        },
        "version": {
          "const": "mag-progress-first-delta.v1"
        },
        "progress_delta_classification": {
          "enum": [
            "deliverable_progress",
            "platform_repair",
            "mixed",
            "typed_blocker",
            "human_gate",
            "stop_loss"
          ]
        },
        "deliverable_progress_delta": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "count",
            "domain_alias"
          ],
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 0
            },
            "domain_alias": {
              "const": "grant_work_progress"
            }
          }
        },
        "platform_repair_delta": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "count",
            "domain_alias"
          ],
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 0
            },
            "domain_alias": {
              "const": "platform_evidence_progress"
            }
          }
        },
        "grant_work_progress": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "maps_to",
            "owner",
            "can_claim_grant_ready",
            "can_claim_submission_ready"
          ],
          "properties": {
            "maps_to": {
              "const": "opl_deliverable_delta"
            },
            "owner": {
              "const": "med-autogrant"
            },
            "can_claim_grant_ready": {
              "const": false
            },
            "can_claim_submission_ready": {
              "const": false
            }
          }
        },
        "platform_evidence_progress": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "maps_to",
            "owner",
            "can_claim_grant_ready",
            "can_claim_fundability_ready",
            "can_claim_export_ready"
          ],
          "properties": {
            "maps_to": {
              "const": "opl_platform_delta"
            },
            "owner": {
              "const": "one-person-lab"
            },
            "can_claim_grant_ready": {
              "const": false
            },
            "can_claim_fundability_ready": {
              "const": false
            },
            "can_claim_export_ready": {
              "const": false
            }
          }
        }
      }
    },
    "statusNarrationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "contract_kind",
        "contract_id",
        "surface_kind",
        "audience",
        "milestone",
        "stage",
        "readiness",
        "remaining_scope",
        "current_blockers",
        "latest_update",
        "next_step",
        "human_gate",
        "facts",
        "narration_policy"
      ],
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "contract_kind": {
          "const": "ai_status_narration"
        },
        "contract_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "surface_kind": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "audience": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "milestone": {
          "type": "object"
        },
        "stage": {
          "type": "object"
        },
        "readiness": {
          "type": "object"
        },
        "remaining_scope": {
          "type": "object"
        },
        "current_blockers": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/nonEmptyString"
          }
        },
        "latest_update": {
          "$ref": "#/$defs/nullableString"
        },
        "next_step": {
          "$ref": "#/$defs/nullableString"
        },
        "human_gate": {
          "type": "object"
        },
        "facts": {
          "type": "object"
        },
        "narration_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "legacy_summary_role",
            "style",
            "answer_checklist"
          ],
          "properties": {
            "mode": {
              "const": "ai_first"
            },
            "legacy_summary_role": {
              "const": "fallback_only"
            },
            "style": {
              "const": "plain_language"
            },
            "answer_checklist": {
              "type": "array",
              "items": {
                "$ref": "common.schema.json#/$defs/nonEmptyString"
            }
          }
        },
        "next_forced_delta": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "required_delta_kind",
            "next_owner",
            "accepted_return_shapes"
          ],
          "properties": {
            "required_delta_kind": {
              "const": "grant_deliverable_progress_delta_or_domain_owned_typed_blocker"
            },
            "next_owner": {
              "const": "med-autogrant"
            },
            "accepted_return_shapes": {
              "type": "array",
              "items": {
                "$ref": "common.schema.json#/$defs/nonEmptyString"
              },
              "contains": {
                "const": "typed_blocker_ref"
              }
            }
          }
        }
      }
    }
    },
    "grantProgressProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_version",
        "projection_kind",
        "workspace_surface_kind",
        "current_stage",
        "current_stage_summary",
        "checkpoint_status",
        "recommended_next_stage",
        "current_blockers",
        "next_system_action",
        "needs_author_decision",
        "author_decision_summary",
        "currentness_resolver",
        "opl_progress_delta",
        "focus",
        "product_entry_surface"
      ],
      "properties": {
        "projection_version": {
          "type": "integer",
          "const": 1
        },
        "projection_kind": {
          "const": "grant_progress"
        },
        "workspace_surface_kind": {
          "const": "nsfc_workspace"
        },
        "current_stage": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "current_stage_summary": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "checkpoint_status": {
          "$ref": "product-entry.schema.json#/$defs/checkpointStatus"
        },
        "recommended_next_stage": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "current_blockers": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/nonEmptyString"
          }
        },
        "next_system_action": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "needs_author_decision": {
          "type": "boolean"
        },
        "author_decision_summary": {
          "$ref": "#/$defs/nullableString"
        },
        "currentness_resolver": {
          "$ref": "#/$defs/currentnessResolver"
        },
        "opl_progress_delta": {
          "$ref": "#/$defs/oplProgressDelta"
        },
        "status_narration_contract": {
          "$ref": "#/$defs/statusNarrationContract"
        },
        "focus": {
          "$ref": "#/$defs/focusPayload"
        },
        "product_entry_surface": {
          "$ref": "#/$defs/productEntrySurface"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "ok",
    "command",
    "grant_run_id",
    "workspace_id",
    "draft_id",
    "lifecycle_stage",
    "input_path",
    "grant_intake_audit",
    "grant_evidence_grounding",
    "progress_projection",
    "family_orchestration"
  ],
  "properties": {
    "ok": {
      "const": true
    },
    "command": {
      "const": "grant-progress"
    },
    "grant_run_id": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "workspace_id": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "draft_id": {
      "$ref": "#/$defs/nullableString"
    },
    "lifecycle_stage": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "input_path": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "grant_intake_audit": {
      "$ref": "grant-intake-audit.schema.json#/$defs/grantIntakeAudit"
    },
    "grant_evidence_grounding": {
      "$ref": "grant-evidence-grounding.schema.json#/$defs/grantEvidenceGrounding"
    },
    "progress_projection": {
      "$ref": "#/$defs/grantProgressProjection"
    },
    "family_orchestration": {
      "$ref": "common.schema.json#/$defs/familyOrchestrationCompanion"
    }
  }
}
