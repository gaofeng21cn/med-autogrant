{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/critique-loop-report.schema.json",
  "title": "CritiqueLoopReport",
  "type": "object",
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "authorityBoundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "stage_transition_authority",
        "stage_transition_authority_role",
        "mag_writes_stage_current_pointer",
        "mag_writes_stage_terminal_state",
        "recommendation_requires_opl_stage_transition_authority"
      ],
      "properties": {
        "surface_kind": {
          "const": "mag_stage_transition_authority_boundary"
        },
        "stage_transition_authority": {
          "const": "one-person-lab"
        },
        "stage_transition_authority_role": {
          "const": "sole_stage_current_terminal_next_writer"
        },
        "mag_writes_stage_current_pointer": {
          "const": false
        },
        "mag_writes_stage_terminal_state": {
          "const": false
        },
        "recommendation_requires_opl_stage_transition_authority": {
          "const": true
        }
      }
    },
    "stageTransitionIntent": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "requires_opl_stage_transition_authority",
        "return_shape"
      ],
      "properties": {
        "surface_kind": {
          "const": "mag_stage_transition_intent_recommendation"
        },
        "requires_opl_stage_transition_authority": {
          "const": true
        },
        "return_shape": {
          "type": "string",
          "enum": [
            "typed_blocker",
            "no_regression_evidence"
          ]
        }
      }
    },
    "authorityReturn": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "result_shape",
        "requires_opl_stage_transition_authority",
        "body_policy"
      ],
      "properties": {
        "surface_kind": {
          "const": "mag_stage_authority_return"
        },
        "result_shape": {
          "type": "string",
          "enum": [
            "typed_blocker",
            "no_regression_evidence"
          ]
        },
        "requires_opl_stage_transition_authority": {
          "const": true
        },
        "body_policy": {
          "const": "refs_only_no_stage_current_or_terminal_write"
        }
      }
    },
    "oplExecutionBoundaryTypedBlocker": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "typed_blocker_ref",
        "required_runtime_owner",
        "required_default_executor_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "mag_opl_execution_boundary_typed_blocker"
        },
        "typed_blocker_ref": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "required_runtime_owner": {
          "const": "one-person-lab"
        },
        "required_default_executor_kind": {
          "const": "codex_cli"
        }
      }
    },
    "loopRoundSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "round",
        "decision",
        "critique_stage",
        "recommended_stage",
        "route_reason"
      ],
      "properties": {
        "round": {
          "type": "integer",
          "minimum": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "ready_for_submission",
            "revision_required",
            "rollback_required"
          ]
        },
        "critique_stage": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "revision_stage": {
          "$ref": "#/$defs/nullableString"
        },
        "recommended_stage": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "route_reason": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "loop_version",
    "loop_status",
    "loop_status_role",
    "stage_transition_authority",
    "authority_boundary",
    "stage_transition_intent",
    "authority_return",
    "started_from_stage",
    "completed_rounds",
    "max_rounds",
    "termination_reason",
    "final_stage",
    "final_recommended_stage",
    "rounds",
    "grant_quality_scorecard",
    "grant_quality_closure_dossier"
  ],
  "properties": {
    "surface_kind": {
      "const": "critique_loop_report"
    },
    "loop_version": {
      "type": "integer",
      "const": 1
    },
    "loop_status": {
      "type": "string",
      "enum": [
        "passed",
        "rollback_required",
        "failed_closed"
      ]
    },
    "loop_status_role": {
      "const": "mag_domain_controller_result_not_opl_stage_terminal"
    },
    "stage_transition_authority": {
      "const": "one-person-lab"
    },
    "authority_boundary": {
      "$ref": "#/$defs/authorityBoundary"
    },
    "stage_transition_intent": {
      "$ref": "#/$defs/stageTransitionIntent"
    },
    "authority_return": {
      "$ref": "#/$defs/authorityReturn"
    },
    "started_from_stage": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "completed_rounds": {
      "type": "integer",
      "minimum": 0
    },
    "max_rounds": {
      "type": "integer",
      "minimum": 1
    },
    "termination_reason": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "final_stage": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "final_recommended_stage": {
      "$ref": "#/$defs/nullableString"
    },
    "rounds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/loopRoundSummary"
      }
    },
    "grant_quality_scorecard": {
      "$ref": "grant-quality-scorecard.schema.json#/$defs/grantQualityScorecard"
    },
    "grant_quality_closure_dossier": {
      "$ref": "grant-quality-closure-dossier.schema.json#/$defs/grantQualityClosureDossier"
    },
    "typed_blocker": {
      "$ref": "#/$defs/oplExecutionBoundaryTypedBlocker"
    }
  }
}
