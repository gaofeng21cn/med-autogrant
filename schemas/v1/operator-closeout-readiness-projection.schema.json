{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/operator-closeout-readiness-projection.schema.json",
  "title": "Med Auto Grant Operator Closeout Readiness Projection",
  "type": "object",
  "$defs": {
    "productionAcceptanceTail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "closed",
        "accepted_return_shape",
        "owner_receipt_ref",
        "scope",
        "can_declare_grant_ready"
      ],
      "properties": {
        "state": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "closed": {
          "type": "boolean"
        },
        "accepted_return_shape": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "owner_receipt_ref": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "scope": {
          "const": "production_acceptance_tail_only"
        },
        "can_declare_grant_ready": {
          "const": false
        }
      }
    },
    "externalEvidenceAccounting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "closed_request_count",
        "remaining_open_request_count",
        "domain_owned_typed_blocker_count",
        "request_accounting_closed",
        "real_external_evidence_complete",
        "request_accounting_closure_equals_real_evidence",
        "remaining_real_evidence_gap_count",
        "remaining_real_evidence_gap_ids"
      ],
      "properties": {
        "state": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "closed_request_count": {
          "type": "integer",
          "minimum": 0
        },
        "remaining_open_request_count": {
          "type": "integer",
          "minimum": 0
        },
        "domain_owned_typed_blocker_count": {
          "type": "integer",
          "minimum": 0
        },
        "request_accounting_closed": {
          "type": "boolean"
        },
        "real_external_evidence_complete": {
          "type": "boolean"
        },
        "request_accounting_closure_equals_real_evidence": {
          "const": false
        },
        "remaining_real_evidence_gap_count": {
          "type": "integer",
          "minimum": 0
        },
        "remaining_real_evidence_gap_ids": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "receiptReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "receipt_refs_ready",
        "quality_ready",
        "submission_ready",
        "missing_category_count",
        "covered_category_count",
        "missing_categories"
      ],
      "properties": {
        "state": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "receipt_refs_ready": {
          "type": "boolean"
        },
        "quality_ready": {
          "const": false
        },
        "submission_ready": {
          "const": false
        },
        "missing_category_count": {
          "type": "integer",
          "minimum": 0
        },
        "covered_category_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_categories": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "operatorAttention": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "attention_id",
        "state",
        "owner"
      ],
      "properties": {
        "attention_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "state": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "owner": {
          "type": "string",
          "enum": [
            "med-autogrant",
            "one-person-lab"
          ]
        },
        "gap_ids": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "missing_categories": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "authorityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_scope",
        "mag_implements_opl_runtime",
        "mag_implements_app_workbench",
        "request_accounting_closure_equals_real_evidence",
        "receipt_refs_ready_equals_quality_ready",
        "production_tail_closure_equals_grant_ready",
        "can_declare_fundability_ready",
        "can_declare_quality_ready",
        "can_declare_export_ready",
        "can_declare_submission_ready"
      ],
      "properties": {
        "projection_scope": {
          "const": "operator_closeout_readiness_only"
        },
        "mag_implements_opl_runtime": {
          "const": false
        },
        "mag_implements_app_workbench": {
          "const": false
        },
        "request_accounting_closure_equals_real_evidence": {
          "const": false
        },
        "receipt_refs_ready_equals_quality_ready": {
          "const": false
        },
        "production_tail_closure_equals_grant_ready": {
          "const": false
        },
        "can_declare_fundability_ready": {
          "const": false
        },
        "can_declare_quality_ready": {
          "const": false
        },
        "can_declare_export_ready": {
          "const": false
        },
        "can_declare_submission_ready": {
          "const": false
        }
      }
    },
    "operatorCloseoutReadinessProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "target_domain_id",
        "owner",
        "state",
        "projection_policy",
        "production_acceptance_tail",
        "external_evidence_accounting",
        "receipt_readiness",
        "operator_attention",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "mag_operator_closeout_readiness_projection"
        },
        "version": {
          "const": "v1"
        },
        "target_domain_id": {
          "const": "med-autogrant"
        },
        "owner": {
          "const": "med-autogrant"
        },
        "state": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "projection_policy": {
          "const": "read_existing_refs_only_distinguish_accounting_closure_from_real_evidence_and_receipt_coverage_from_quality_readiness"
        },
        "production_acceptance_tail": {
          "$ref": "#/$defs/productionAcceptanceTail"
        },
        "external_evidence_accounting": {
          "$ref": "#/$defs/externalEvidenceAccounting"
        },
        "receipt_readiness": {
          "$ref": "#/$defs/receiptReadiness"
        },
        "operator_attention": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/operatorAttention"
          }
        },
        "authority_boundary": {
          "$ref": "#/$defs/authorityBoundary"
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/$defs/operatorCloseoutReadinessProjection"
    }
  ]
}
