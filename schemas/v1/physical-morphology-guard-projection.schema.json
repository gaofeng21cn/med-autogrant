{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/physical-morphology-guard-projection.schema.json",
  "title": "Med Auto Grant Physical Morphology Guard Projection",
  "type": "object",
  "$defs": {
    "forbiddenRoleFlags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scheduler_daemon_owner": {
          "type": "boolean"
        },
        "attempt_ledger_owner": {
          "type": "boolean"
        },
        "local_journal_owner": {
          "type": "boolean"
        },
        "generic_runtime_owner": {
          "type": "boolean"
        },
        "app_workbench_owner": {
          "type": "boolean"
        },
        "compatibility_alias_owner": {
          "type": "boolean"
        }
      }
    },
    "blockerReason": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "reason"
      ],
      "properties": {
        "reason": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "sourceItemProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "module_id",
        "declared_role",
        "evidence_refs",
        "forbidden_role_flags",
        "true_forbidden_flags",
        "blocker_reasons",
        "required_next_evidence_refs",
        "deletion_readiness",
        "allowed"
      ],
      "properties": {
        "path": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "module_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "declared_role": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "evidence_refs": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "forbidden_role_flags": {
          "$ref": "#/$defs/forbiddenRoleFlags"
        },
        "true_forbidden_flags": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "blocker_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/blockerReason"
          }
        },
        "required_next_evidence_refs": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "deletion_readiness": {
          "$ref": "#/$defs/deletionReadiness"
        },
        "allowed": {
          "type": "boolean"
        }
      }
    },
    "deletionReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "state",
        "physical_delete_authorized",
        "owner_receipt_required_ref",
        "typed_blocker_allowed_ref",
        "missing_retirement_evidence_refs",
        "next_owner_delta_required",
        "delete_or_tombstone_only_after_gate",
        "blocked_by_surface_gate",
        "claims_grant_ready",
        "claims_submission_ready",
        "claims_production_ready"
      ],
      "properties": {
        "surface_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "state": {
          "const": "blocked_by_surface_evidence_or_owner_receipt"
        },
        "physical_delete_authorized": {
          "const": false
        },
        "owner_receipt_required_ref": {
          "const": "owner_receipt://mag/physical_delete_or_tombstone_authorization"
        },
        "typed_blocker_allowed_ref": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "missing_retirement_evidence_refs": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "next_owner_delta_required": {
          "const": "mag_owner_physical_delete_receipt_or_domain_owned_typed_blocker_required"
        },
        "delete_or_tombstone_only_after_gate": {
          "const": true
        },
        "blocked_by_surface_gate": {
          "type": "boolean"
        },
        "claims_grant_ready": {
          "const": false
        },
        "claims_submission_ready": {
          "const": false
        },
        "claims_production_ready": {
          "const": false
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_item_count",
        "allowed_count",
        "blocked_count",
        "evidence_gated_item_count",
        "external_evidence_ref_count"
      ],
      "properties": {
        "source_item_count": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_gated_item_count": {
          "type": "integer",
          "minimum": 0
        },
        "external_evidence_ref_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claims_scheduler_daemon_owner",
        "claims_attempt_ledger_owner",
        "claims_local_journal_owner",
        "claims_generic_runtime_owner",
        "claims_app_workbench_owner",
        "claims_compatibility_alias_owner",
        "claims_physical_morphology_cleanup_complete",
        "claims_ready_for_owner_receipted_cleanup"
      ],
      "properties": {
        "claims_scheduler_daemon_owner": {
          "const": false
        },
        "claims_attempt_ledger_owner": {
          "const": false
        },
        "claims_local_journal_owner": {
          "const": false
        },
        "claims_generic_runtime_owner": {
          "const": false
        },
        "claims_app_workbench_owner": {
          "const": false
        },
        "claims_compatibility_alias_owner": {
          "const": false
        },
        "claims_physical_morphology_cleanup_complete": {
          "const": false
        },
        "claims_ready_for_owner_receipted_cleanup": {
          "type": "boolean"
        }
      }
    },
    "authorityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_scope",
        "mag_role",
        "mag_implements_opl_runtime",
        "mag_implements_scheduler_daemon",
        "mag_implements_attempt_ledger",
        "mag_implements_local_journal",
        "mag_implements_app_workbench",
        "mag_restores_compatibility_alias",
        "can_declare_physical_cleanup_complete",
        "can_declare_ready_for_owner_receipted_cleanup"
      ],
      "properties": {
        "projection_scope": {
          "const": "source_path_module_role_evidence_refs_only"
        },
        "mag_role": {
          "const": "physical_morphology_read_guard_projection"
        },
        "mag_implements_opl_runtime": {
          "const": false
        },
        "mag_implements_scheduler_daemon": {
          "const": false
        },
        "mag_implements_attempt_ledger": {
          "const": false
        },
        "mag_implements_local_journal": {
          "const": false
        },
        "mag_implements_app_workbench": {
          "const": false
        },
        "mag_restores_compatibility_alias": {
          "const": false
        },
        "can_declare_physical_cleanup_complete": {
          "const": false
        },
        "can_declare_ready_for_owner_receipted_cleanup": {
          "type": "boolean"
        }
      }
    },
    "strictSourcePurityGuard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guard_id",
        "state",
        "source_ref_integrity_state",
        "source_ref_integrity_guard_ref",
        "active_path_scan_policy_ref",
        "contract_guard_ref",
        "guard_role",
        "allowed_readback_outputs",
        "forbidden_readback_outputs",
        "fail_closed_conditions",
        "claims",
        "authority_boundary"
      ],
      "properties": {
        "guard_id": {
          "const": "mag.physical_morphology.strict_source_purity_no_second_truth_guard.v1"
        },
        "state": {
          "enum": [
            "passed",
            "failed"
          ]
        },
        "source_ref_integrity_state": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "source_ref_integrity_guard_ref": {
          "const": "source_ref_integrity_guard"
        },
        "active_path_scan_policy_ref": {
          "const": "contracts/private_functional_surface_policy.json#/physical_source_morphology_policy/active_path_scan_policy"
        },
        "contract_guard_ref": {
          "const": "contracts/private_functional_surface_policy.json#/physical_source_morphology_policy/strict_source_purity_no_second_truth_guard"
        },
        "guard_role": {
          "const": "source_ref_integrity_and_active_path_scan_are_no_second_truth_guards_not_readiness_or_delete_authority"
        },
        "allowed_readback_outputs": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "forbidden_readback_outputs": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "fail_closed_conditions": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "claims": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "claims_strict_source_purity_complete",
            "claims_source_ref_integrity_complete",
            "claims_default_caller_cutover",
            "claims_physical_delete_authorized",
            "claims_grant_ready",
            "claims_submission_ready",
            "claims_production_ready"
          ],
          "properties": {
            "claims_strict_source_purity_complete": {
              "const": false
            },
            "claims_source_ref_integrity_complete": {
              "const": false
            },
            "claims_default_caller_cutover": {
              "const": false
            },
            "claims_physical_delete_authorized": {
              "const": false
            },
            "claims_grant_ready": {
              "const": false
            },
            "claims_submission_ready": {
              "const": false
            },
            "claims_production_ready": {
              "const": false
            }
          }
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "guard_can_write_grant_truth",
            "guard_can_create_alias_files",
            "guard_can_sign_owner_receipt",
            "guard_can_create_typed_blocker",
            "guard_can_authorize_physical_delete",
            "guard_can_claim_default_caller_cutover",
            "guard_can_claim_generated_hosted_live_consumption",
            "guard_can_claim_grant_readiness",
            "guard_can_claim_submission_ready",
            "guard_can_claim_production_ready"
          ],
          "properties": {
            "guard_can_write_grant_truth": {
              "const": false
            },
            "guard_can_create_alias_files": {
              "const": false
            },
            "guard_can_sign_owner_receipt": {
              "const": false
            },
            "guard_can_create_typed_blocker": {
              "const": false
            },
            "guard_can_authorize_physical_delete": {
              "const": false
            },
            "guard_can_claim_default_caller_cutover": {
              "const": false
            },
            "guard_can_claim_generated_hosted_live_consumption": {
              "const": false
            },
            "guard_can_claim_grant_readiness": {
              "const": false
            },
            "guard_can_claim_submission_ready": {
              "const": false
            },
            "guard_can_claim_production_ready": {
              "const": false
            }
          }
        }
      }
    },
    "physicalMorphologyGuardProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "target_domain_id",
        "owner",
        "projection_role",
        "state",
        "projection_policy",
        "allowed_roles",
        "external_evidence_refs",
        "missing_external_evidence_refs",
        "required_next_evidence_refs",
        "allowed_count",
        "blocked_count",
        "allowed_items",
        "blocked_items",
        "strict_source_purity_no_second_truth_guard",
        "summary",
        "claims",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "mag_physical_morphology_guard_projection"
        },
        "version": {
          "const": "v1"
        },
        "target_domain_id": {
          "const": "med-autogrant"
        },
        "owner": {
          "const": "med-autogrant"
        },
        "projection_role": {
          "const": "repo_local_physical_morphology_refs_role_guard"
        },
        "state": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "projection_policy": {
          "const": "refs_and_role_projection_only_no_runtime_no_workbench_no_scheduler_no_lifecycle_owner_no_compat_alias"
        },
        "allowed_roles": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "external_evidence_refs": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "missing_external_evidence_refs": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "required_next_evidence_refs": {
          "$ref": "common.schema.json#/$defs/stringList"
        },
        "allowed_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceItemProjection"
          }
        },
        "blocked_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceItemProjection"
          }
        },
        "strict_source_purity_no_second_truth_guard": {
          "$ref": "#/$defs/strictSourcePurityGuard"
        },
        "summary": {
          "$ref": "#/$defs/summary"
        },
        "claims": {
          "$ref": "#/$defs/claims"
        },
        "authority_boundary": {
          "$ref": "#/$defs/authorityBoundary"
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/$defs/physicalMorphologyGuardProjection"
    }
  ]
}
