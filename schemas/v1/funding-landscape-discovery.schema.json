{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/funding-landscape-discovery.schema.json",
  "title": "FundingLandscapeDiscovery",
  "type": "object",
  "$defs": {
    "sourceReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_kind",
        "source_url",
        "fetched_at",
        "item_count"
      ],
      "properties": {
        "source_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "source_kind": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "source_url": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "fetched_at": {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        "item_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "fundingOpportunityProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "brief_id",
        "provenance_status",
        "provenance_score",
        "source_ids"
      ],
      "properties": {
        "brief_id": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "provenance_status": {
          "$ref": "common.schema.json#/$defs/nonEmptyString"
        },
        "provenance_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "source_ids": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    },
    "discoverySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "discovery_source",
        "evaluated_catalog_count",
        "post_filter_catalog_count",
        "blocked_by_rules_count",
        "source_receipt_count",
        "applied_filters",
        "required_input_fields"
      ],
      "properties": {
        "decision": {
          "const": "discovered"
        },
        "discovery_source": {
          "type": "string",
          "enum": [
            "catalog_static",
            "official_live",
            "official_cached"
          ]
        },
        "evaluated_catalog_count": {
          "type": "integer",
          "minimum": 1
        },
        "post_filter_catalog_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_by_rules_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_receipt_count": {
          "type": "integer",
          "minimum": 0
        },
        "applied_filters": {
          "type": "object",
          "additionalProperties": {
            "$ref": "common.schema.json#/$defs/stringList"
          }
        },
        "required_input_fields": {
          "$ref": "common.schema.json#/$defs/stringList"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "discovery_version",
    "discovery_input_id",
    "funding_opportunity_pool",
    "funding_opportunity_provenance",
    "candidate_count",
    "source_receipts",
    "discovery_summary"
  ],
  "properties": {
    "surface_kind": {
      "const": "funding_landscape_discovery"
    },
    "discovery_version": {
      "type": "integer",
      "const": 1
    },
    "discovery_input_id": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "funding_opportunity_pool": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "funding-opportunity-brief.schema.json"
      }
    },
    "funding_opportunity_provenance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fundingOpportunityProvenance"
      }
    },
    "candidate_count": {
      "type": "integer",
      "minimum": 1
    },
    "source_receipts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceReceipt"
      }
    },
    "discovery_summary": {
      "$ref": "#/$defs/discoverySummary"
    }
  }
}
