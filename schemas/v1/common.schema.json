{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/common.schema.json",
  "title": "Med Auto Grant Common Types",
  "type": "object",
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "stringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "default": []
    },
    "mode": {
      "type": "string",
      "enum": [
        "auto",
        "human_in_the_loop",
        "mixed"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "created_at",
        "updated_at",
        "source_mode"
      ],
      "properties": {
        "schema_version": {
          "const": "v1"
        },
        "created_at": {
          "$ref": "#/$defs/timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        },
        "source_mode": {
          "$ref": "#/$defs/mode"
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "notes": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "evidencePointer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "label",
        "source_type"
      ],
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "publication",
            "project",
            "preliminary_result",
            "external_reference",
            "cv_item",
            "draft_section",
            "other"
          ]
        },
        "uri": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "criterionAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weight",
        "judgment"
      ],
      "properties": {
        "weight": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "judgment": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "blocking_issues": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "familyReferenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_kind",
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "type": "string",
          "enum": [
            "repo_path",
            "json_pointer",
            "workspace_locator",
            "external_url"
          ]
        },
        "ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "familyGatePreview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id"
      ],
      "properties": {
        "gate_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "type": "string",
          "enum": [
            "requested",
            "approved",
            "rejected",
            "changes_requested"
          ]
        },
        "review_surface": {
          "$ref": "#/$defs/familyReferenceRef"
        }
      }
    },
    "familyActionGraphNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_kind",
        "title"
      ],
      "properties": {
        "node_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "node_kind": {
          "type": "string",
          "enum": [
            "intake",
            "research",
            "authoring",
            "audit",
            "review",
            "publish",
            "operator_step",
            "controller",
            "tool_call"
          ]
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "executor_hint": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "produces_checkpoint": {
          "type": "boolean"
        }
      }
    },
    "familyActionGraphEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "to": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "on": {
          "type": "string",
          "enum": [
            "success",
            "failure",
            "decision",
            "manual_resume"
          ]
        },
        "condition": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "familyActionGraphHumanGateBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "trigger_nodes"
      ],
      "properties": {
        "gate_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "trigger_nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "blocking": {
          "type": "boolean"
        }
      }
    },
    "familyActionGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "graph_id",
        "target_domain_id",
        "graph_kind",
        "nodes",
        "edges",
        "entry_nodes"
      ],
      "properties": {
        "version": {
          "const": "family-action-graph.v1"
        },
        "graph_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "graph_kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "graph_version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/familyActionGraphNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/familyActionGraphEdge"
          }
        },
        "entry_nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "exit_nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "human_gates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/familyActionGraphHumanGateBinding"
          }
        },
        "checkpoint_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "none",
                "node_boundary",
                "explicit_nodes"
              ]
            },
            "checkpoint_nodes": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          }
        },
        "notes": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "familyResumeContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "session_locator_field"
      ],
      "properties": {
        "surface_kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "session_locator_field": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "checkpoint_locator_field": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "evidenceTrustLevel": {
      "type": "string",
      "enum": [
        "trusted",
        "usable_with_verification",
        "reference_only",
        "stale_or_conflicting",
        "missing_context"
      ]
    },
    "familyTrustRankedEvidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_kind",
        "ref",
        "trust_rank"
      ],
      "properties": {
        "ref_kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "trust_rank": {
          "type": "integer",
          "minimum": 1
        },
        "trust_note": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "supports": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "familyGroundingScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_kind",
        "summary",
        "scope_refs"
      ],
      "properties": {
        "scope_kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scope_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/familyReferenceRef"
          }
        }
      }
    },
    "familyIntakeEvidenceAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "verdict": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "audited_at": {
          "$ref": "#/$defs/timestamp"
        },
        "summary_ref": {
          "$ref": "#/$defs/familyReferenceRef"
        }
      }
    },
    "familyIntakeEvidenceCompanion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "target_domain_id",
        "intake_audit",
        "trust_ranked_evidence_refs",
        "grounding_scope"
      ],
      "properties": {
        "version": {
          "const": "family-intake-evidence-companion.v1"
        },
        "target_domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "intake_audit": {
          "$ref": "#/$defs/familyIntakeEvidenceAudit"
        },
        "trust_ranked_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/familyTrustRankedEvidenceRef"
          }
        },
        "grounding_scope": {
          "$ref": "#/$defs/familyGroundingScope"
        },
        "human_gate_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/familyReferenceRef"
          }
        },
        "checkpoint_lineage_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/familyReferenceRef"
          }
        }
      }
    },
    "familyOrchestrationCompanion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_graph_ref",
        "human_gates",
        "resume_contract",
        "action_graph"
      ],
      "properties": {
        "action_graph_ref": {
          "$ref": "#/$defs/familyReferenceRef"
        },
        "human_gates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/familyGatePreview"
          }
        },
        "resume_contract": {
          "$ref": "#/$defs/familyResumeContract"
        },
        "action_graph": {
          "$ref": "#/$defs/familyActionGraph"
        },
        "event_envelope_surface": {
          "$ref": "#/$defs/familyReferenceRef"
        },
        "checkpoint_lineage_surface": {
          "$ref": "#/$defs/familyReferenceRef"
        },
        "intake_evidence_companion": {
          "$ref": "#/$defs/familyIntakeEvidenceCompanion"
        }
      }
    }
  }
}
