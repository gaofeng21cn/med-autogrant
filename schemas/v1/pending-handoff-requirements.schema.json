{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.med-autogrant.local/v1/pending-handoff-requirements.schema.json",
  "title": "Med Auto Grant Pending Handoff Requirements",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_kind",
    "workspace_surface_kind",
    "required_domain_surfaces",
    "required_identity_fields",
    "required_summary_fields",
    "required_gate_fields"
  ],
  "properties": {
    "contract_kind": {
      "$ref": "common.schema.json#/$defs/nonEmptyString"
    },
    "workspace_surface_kind": {
      "const": "nsfc_workspace"
    },
    "required_domain_surfaces": {
      "type": "array",
      "items": {
        "$ref": "service-safe-domain-surface.schema.json"
      },
      "minItems": 2
    },
    "required_identity_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "grant_run_id",
          "workspace_id",
          "draft_id"
        ]
      },
      "minItems": 2
    },
    "required_summary_fields": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/nonEmptyString"
      },
      "minItems": 1
    },
    "required_gate_fields": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/nonEmptyString"
      },
      "minItems": 1
    }
  }
}
