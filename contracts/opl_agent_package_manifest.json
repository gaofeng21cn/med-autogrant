{
  "surface_kind": "opl_agent_package_manifest.v1",
  "agent_id": "mag",
  "package_id": "mag",
  "display_name": "Med Auto Grant",
  "publisher": "one-person-lab",
  "version": "0.3.5",
  "source": "first_party_repo_local",
  "carrier_source_role": "codex_plugin_default_carrier_not_package_truth",
  "schema_ref": "one-person-lab/contracts/opl-framework/agent-package-manifest.schema.json",
  "machine_boundary": "This repo-local sidecar declares OPL Agent Package identity and carrier locators. OPL release authority generates published artifact refs, digests, channels, and receipts; the repo plugin directory and lifecycle module fields remain carrier locators, not package truth or domain truth owners.",
  "codex_surface": {
    "plugin_id": "med-autogrant",
    "standalone_distribution": "repo_carrier_source",
    "required_skill_ids": [
      "med-autogrant"
    ],
    "bundled_capability_package_ids": [
      "mas-scholar-skills"
    ],
    "user_install_action_count": 1
  },
  "lifecycle": {
    "owner": "opl_packages",
    "module_id": "medautogrant",
    "commands": {
      "install": "opl packages install mag",
      "update": "opl packages update mag",
      "uninstall": "opl packages uninstall mag"
    },
    "repo_local_installer_allowed": false,
    "repo_local_marketplace_mutation_allowed": false,
    "repo_local_user_symlink_mutation_allowed": false
  },
  "capability_dependencies": [
    {
      "module_id": "scholarskills",
      "package_id": "mas-scholar-skills",
      "kind": "framework_capability_package",
      "required": false,
      "dependency_kind": "optional_enhancement",
      "version_requirement": ">=0.2.19 <0.3.0",
      "capability_abi": "mas-scholar-skills.v1",
      "consumer_profile_id": "mag-medical-grant.v1",
      "provider_manifest_ref": "mas-scholar-skills/contracts/opl_capability_package_manifest.json",
      "required_export_ids": [
        "medical-research-lit",
        "medical-statistical-review",
        "medical-methodology-planner",
        "medical-evidence-integrity-reviewer",
        "medical-evidence-synthesis-and-claim-map",
        "medical-reference-integrity-auditor"
      ],
      "required_module_ids": [
        "mas-scholar-skills.lit",
        "mas-scholar-skills.stats",
        "mas-scholar-skills.review",
        "mas-scholar-skills.data",
        "mas-scholar-skills.reference-provider-adapters",
        "mas-scholar-skills.scientific-search-adapters"
      ],
      "required_for": [
        "mag_professional_grant_research",
        "mag_methodology_and_statistical_review",
        "mag_evidence_and_reference_integrity"
      ],
      "codex_distribution": "bundled",
      "opl_distribution": "managed_dependency",
      "developer_distribution": "source_checkout",
      "install_owner": "one-person-lab",
      "install_update_source": "ghcr_capability_packages_channel",
      "sync_scopes": [
        "workspace",
        "quest"
      ],
      "sync_command_refs": [
        "opl packages activate mag --scope workspace --target-workspace <workspace-root> --json",
        "opl packages activate mag --scope quest --target-quest <quest-root> --json"
      ],
      "activation_materialization": {
        "required": false,
        "owner": "one-person-lab",
        "trigger": "explicit_optional_enhancement_activation",
        "scopes": [
          "workspace",
          "quest"
        ],
        "required_skill_ids_source": "provider_manifest_selected_consumer_profile_required_export_ids",
        "target_path_template": "<scope-root>/.codex/skills/<skill-id>",
        "receipt_required": false
      },
      "missing_or_incompatible_policy": "continue_with_consumer_core_and_record_diagnostic",
      "provider_completion_is_mag_completion": false,
      "blocking_policy": {
        "mag_install": false,
        "stage_launch": false,
        "stage_route": false,
        "operational_readiness": false,
        "grant_core": false,
        "fundability_core": false,
        "quality_core": false,
        "export_core": false,
        "typed_blocker": false
      },
      "authority_boundary": {
        "can_write_domain_truth": false,
        "can_sign_owner_receipt": false,
        "can_create_typed_blocker": false,
        "can_write_runtime_queue": false,
        "can_claim_fundability_verdict": false,
        "can_claim_quality_verdict": false,
        "can_claim_export_readiness": false,
        "can_gate_mag_install": false,
        "can_gate_mag_stage_route": false,
        "can_gate_mag_operational_readiness": false
      }
    }
  ]
}
