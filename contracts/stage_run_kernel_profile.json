{
  "surface_kind": "opl_stage_run_kernel_profile",
  "version": "stage-run-kernel-profile.v1",
  "domain_id": "med-autogrant",
  "owner": "med-autogrant",
  "state": "active_contract",
  "purpose": "Machine-readable StageRun Kernel profile for Stage Native grant authoring execution: stage folder, stage_manifest, role artifacts, and MAG owner receipt or typed blocker.",
  "machine_boundary": "This profile defines a minimal StageRun state shell and authority boundary. It does not declare grant closure, fundability readiness, submission readiness, domain readiness, quality readiness, artifact readiness, package freshness, or production readiness.",
  "kernel_contract_ref": "contracts/opl-framework/stage-run-kernel-contract.json",
  "stage_manifest_schema_ref": "contracts/opl-framework/stage-manifest.schema.json",
  "role_artifact_ref_schema_ref": "contracts/opl-framework/role-artifact-ref.schema.json",
  "owner_receipt_schema_ref": "contracts/opl-framework/stage-owner-receipt.schema.json",
  "typed_blocker_schema_ref": "contracts/opl-framework/stage-typed-blocker.schema.json",
  "stage_artifact_kernel_adoption_ref": "contracts/stage_artifact_kernel_adoption.json",
  "owner_receipt_contract_ref": "contracts/owner_receipt_contract.json",
  "controlled_canary_evidence_ref": "contracts/stage_run_canary_evidence.json",
  "live_stage_run_progress_evidence_ref": "contracts/live_stage_run_progress_evidence.json",
  "owner_chain_live_progress_provenance_ref": "contracts/external_evidence/mag-evidence-receipt-ledger.json#/owner_chain_live_progress_evidence_lane",
  "opl_contract_refs": {
    "owner": "one-person-lab",
    "domain_repo_role": "consumer_profile_ref_only",
    "repo_local_file_required": false,
    "local_resolution_policy": "do_not_copy_opl_framework_contracts_into_domain_repo",
    "refs": [
      "contracts/opl-framework/stage-run-kernel-contract.json",
      "contracts/opl-framework/stage-manifest.schema.json",
      "contracts/opl-framework/role-artifact-ref.schema.json",
      "contracts/opl-framework/stage-owner-receipt.schema.json",
      "contracts/opl-framework/stage-typed-blocker.schema.json"
    ]
  },
  "kernel_role": "minimal_state_shell_not_domain_controller_system",
  "stage_native_unit": [
    "stage_folder",
    "stage_manifest",
    "role_artifacts",
    "owner_receipt_or_typed_blocker"
  ],
  "required_object_models": [
    "StageRun",
    "RoleArtifactRef",
    "OwnerReceipt",
    "TypedBlocker",
    "ReadModel"
  ],
  "stage_run_state_machine": {
    "provider_completion_counts_as_domain_accepted": false,
    "file_presence_counts_as_stage_complete": false,
    "latest_json_counts_as_domain_accepted": false,
    "read_model_counts_as_transition_authority": false
  },
  "launch_admission_policy": {
    "hard_blockers": [
      "identity",
      "owner",
      "scope",
      "selected_executor",
      "authority_boundary",
      "required_role_artifacts",
      "receipt_or_blocker_shape",
      "forbidden_write",
      "replay_audit_lineage"
    ],
    "advisory_refs": [
      "prompt_refs",
      "skill_refs",
      "tool_affordance_refs",
      "knowledge_refs",
      "rubric_refs",
      "evaluation_refs"
    ],
    "advisory_refs_can_block_launch": false
  },
  "default_read_surface": {
    "root": "stage_run_current_owner_delta",
    "raw_worklist_default": false,
    "readiness_default": false,
    "replay_packet_default": false
  },
  "transition_authority": {
    "terminal_transition_authority": "owner_receipt_or_typed_blocker",
    "provider_completion_counts_as_transition": false,
    "file_presence_counts_as_transition": false
  },
  "authority_boundary": {
    "opl_can_write_domain_truth": false,
    "opl_can_mutate_artifact_body": false,
    "opl_can_sign_domain_owner_receipt": false,
    "opl_can_create_typed_blocker": false,
    "opl_can_authorize_quality_or_export": false,
    "provider_completion_counts_as_domain_accepted": false,
    "read_model_can_be_truth_source": false
  },
  "domain_authority_retained": [
    "grant_truth",
    "fundability_verdict",
    "authoring_quality_verdict",
    "submission_export_authority",
    "grant_strategy_memory_accept_reject",
    "owner_receipt",
    "typed_blocker"
  ],
  "domain_thinning_policy": {
    "mag_long_term_role": "declarative_grant_pack_plus_refs_only_adapter_plus_minimal_authority_functions",
    "opl_hosted_runtime_owner": "one-person-lab",
    "retired_or_thinned_mag_surfaces": [
      "legacy_scheduler_surface",
      "repo_owned_runner",
      "session_store",
      "status_shell",
      "workbench_wrapper",
      "runtime_journal_cadence",
      "generic_transition_runner",
      "app_workbench_wrapper"
    ],
    "allowed_legacy_roles": [
      "migration_input",
      "diagnostic",
      "provenance",
      "refs_only_adapter",
      "tombstone"
    ],
    "forbidden_resurrection": [
      "mag_owned_durable_scheduler",
      "mag_owned_attempt_ledger",
      "mag_owned_session_store",
      "mag_owned_status_workbench",
      "mag_owned_generic_runner",
      "mag_owned_workflow_wrapper"
    ],
    "physical_delete_gate": [
      "replacement_parity",
      "no_active_caller",
      "mag_owner_receipt_or_typed_blocker",
      "no_forbidden_write",
      "tombstone_or_provenance_ref"
    ]
  },
  "legacy_runtime_residue_guard": {
    "surface_id": "legacy_runtime_residue",
    "state": "active_guard",
    "default_runtime_owner": "one-person-lab",
    "residue_role": "history_or_tombstone_only",
    "guard_scope": "stage_run_profile_and_controlled_canary_follow_through",
    "source_refs": [
      "contracts/stage_run_kernel_profile.json#/domain_thinning_policy",
      "contracts/functional_privatization_audit.json#/physical_source_morphology/surface_classifications/legacy_runtime_residue",
      "docs/history/specs/2026-04-13-hermes-native-critique-proof-tombstone.md"
    ],
    "allowed_remaining_roles": [
      "migration_input",
      "diagnostic",
      "provenance",
      "refs_only_adapter",
      "tombstone"
    ],
    "forbidden_default_active_paths": [
      "mag_owned_durable_scheduler",
      "mag_owned_attempt_ledger",
      "mag_owned_session_store",
      "mag_owned_status_workbench",
      "mag_owned_generic_runner",
      "mag_owned_workflow_wrapper"
    ],
    "required_negative_guards": {
      "mag_owned_durable_scheduler": false,
      "mag_owned_attempt_ledger": false,
      "mag_owned_session_store": false,
      "mag_owned_status_workbench": false,
      "mag_owned_generic_runner": false,
      "mag_owned_workflow_wrapper": false,
      "runtime_journal_cadence_default": false,
      "controlled_canary_can_close_residue_retirement": false,
      "conformance_pass_can_close_residue_retirement": false
    },
    "closeout_gate": {
      "physical_delete_requires": [
        "replacement_parity",
        "no_active_caller",
        "mag_owner_receipt_or_typed_blocker",
        "no_forbidden_write",
        "tombstone_or_provenance_ref"
      ],
      "canary_fixture_can_close_residue_retirement": false,
      "conformance_pass_can_close_residue_retirement": false
    }
  },
  "stage_internal_strategy_policy": {
    "strategy_refs_are_advisory": true,
    "strategies_are_stage_internal_execution_choices": true,
    "strategy_artifacts_are_refs_only_evidence": true,
    "strategy_artifacts_can_define_stage_transition": false,
    "hard_coded_workflow_allowed": false,
    "stage_internal_strategy_refs": [
      "candidate_generation",
      "reflection",
      "ranking",
      "revision",
      "meta_review"
    ],
    "canary": {
      "controlled_evidence_ref": "contracts/stage_run_canary_evidence.json",
      "candidate_reflection_ranking_revision_meta_review_are_not_workflow_steps": true,
      "candidate_pool_is_stage_internal_artifact": true,
      "reflection_is_stage_internal_evidence_ref": true,
      "ranking_is_stage_internal_evidence_ref": true,
      "revision_is_stage_internal_strategy_or_domain_stage_ref": true,
      "meta_review_is_stage_internal_evidence_ref": true
    }
  },
  "projection_boundary": {
    "read_models_are_rebuildable": true,
    "allowed_projection_inputs": [
      "StageRun_event_log",
      "stage_manifest_ref",
      "role_artifact_refs",
      "owner_receipt_refs",
      "typed_blocker_refs",
      "current_owner_delta_ref"
    ],
    "projection_can_write_truth": false,
    "projection_can_authorize_next_stage": false
  }
}
